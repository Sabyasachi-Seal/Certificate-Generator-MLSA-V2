{
    "outputDirectory": ".",
    "functions": {
        "api/send.py": {
            "runtime": "@vercel/python@6.47.1",
            "memory": 1024,
            "maxDuration": 60
        }
    },
    "routes": [
        {
            "src": "/api/send",
            "dest": "/api/send.py"
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ]
}